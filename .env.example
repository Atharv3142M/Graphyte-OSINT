# Unified Enterprise OSINT Platform - Environment Template
# Copy to .env and adjust for your environment

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Celery
# -----------------------------------------------------------------------------
USE_CELERY=true
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_HARD_TIMEOUT=300

# -----------------------------------------------------------------------------
# Redis (Celery broker)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# RabbitMQ (Pub/Sub event bus)
# -----------------------------------------------------------------------------
RABBITMQ_HOST=localhost
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=dev_rabbitmq_secret
RABBITMQ_VHOST=/
RABBITMQ_URL=amqp://admin:dev_rabbitmq_secret@localhost:5672/

# -----------------------------------------------------------------------------
# Neo4j (graph DB for STIX)
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_HTTP_URI=http://localhost:7474
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=dev_neo4j_secret

# -----------------------------------------------------------------------------
# Weaviate (vector DB)
# -----------------------------------------------------------------------------
WEAVIATE_HTTP_URI=http://localhost:8080
WEAVIATE_HTTP_PORT=8080
WEAVIATE_GRPC_PORT=50051

# -----------------------------------------------------------------------------
# PostgreSQL (configs, multi-tenant, audit logs)
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=osint
POSTGRES_PASSWORD=dev_postgres_secret
POSTGRES_DB=osint_platform
DATABASE_URL=postgresql://osint:dev_postgres_secret@localhost:5432/osint_platform

# -----------------------------------------------------------------------------
# External API keys (placeholders)
# -----------------------------------------------------------------------------
SHODAN_API_KEY=YOUR_SHODAN_API_KEY
CENSYS_API_ID=YOUR_CENSYS_API_ID
CENSYS_API_SECRET=YOUR_CENSYS_API_SECRET
